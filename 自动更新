name: Auto Update Live Sources

on:
  schedule:
    # 每天北京时间 06:00 和 18:00 自动执行一次
    - cron: '0 22,10 * * *' 
  workflow_dispatch: # 允许在 GitHub 界面手动触发

jobs:
  update-sources:
    runs-on: ubuntu-latest
    
    steps:
      - name: Checkout repository
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.x'

      - name: Install dependencies
        run: pip install requests # 根据你脚本的实际依赖进行修改

      - name: Run scraper script
        run: python your_scraper_script.py # 替换为你的脚本文件名

      - name: Commit and push changes
        run: |
          git config --global user.name 'github-actions[bot]'
          git config --global user.email 'github-actions[bot]@users.noreply.github.com'
          git add .
          # 只有当文件有变化时才提交，避免空提交
          git diff --staged --quiet || git commit -m "Auto-update live sources"
          git push



name: Update Live Sources

on:
  schedule:
    - cron: '0 2,14 * * *'  # 每天 UTC 02:00 和 14:00（北京时间 10:00/22:00）
  workflow_dispatch:  # 允许手动触发

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4
        with:
          ref: main

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'

      - name: Install dependencies
        run: pip install requests

      - name: Run scraper script
        id: run_script
        run: |
          python update_live_sources.py
          echo "changes_detected=true" >> $GITHUB_OUTPUT

      - name: Commit changes
        if: steps.run_script.outputs.changes_detected == 'true'
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"
          git add live_sources.m3u
          git commit -m "Auto-update: $(date -u +'%Y-%m-%d %H:%M UTC')" || exit 0
          git push


